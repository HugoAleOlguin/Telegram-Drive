{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Telegram Drive",
  "version": "1.6.5",
  "identifier": "com.telegramdrive.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Telegram Drive",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": [
          "es-ES",
          "en-US"
        ]
      }
    }
  }
}
